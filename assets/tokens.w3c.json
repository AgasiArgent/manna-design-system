      "300": { "$value": "#8BA6A0", "$type": "color" },
      "400": { "$value": "#5C7973", "$type": "color" },
      "500": { "$value": "#2E4B46", "$type": "color" },
      "600": { "$value": "#263D39", "$type": "color" },
      "700": { "$value": "#1E302D", "$type": "color" },
      "800": { "$value": "#162321", "$type": "color" },
      "900": { "$value": "#0E1614", "$type": "color" }
    },
    "accent": {
      "50":  { "$value": "#F4FCF1", "$type": "color" },
      "100": { "$value": "#E6F8E1", "$type": "color" },
