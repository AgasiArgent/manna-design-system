      "700": { "$value": "#5FA051", "$type": "color" },
      "800": { "$value": "#437639", "$type": "color" },
      "900": { "$value": "#294A22", "$type": "color" }
    },
    "cta": {
      "500": { "$value": "#FF6B55", "$type": "color" },
      "600": { "$value": "#D95B48", "$type": "color" },
      "700": { "$value": "#B34B3C", "$type": "color" }
    },
    "warm": {
      "500": { "$value": "#C4956A", "$type": "color" }
    },
    "ink": {
      "500": { "$value": "#141D24", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "brand": { "$value": "Baloo 2, system-ui, sans-serif", "$type": "fontFamily" },
